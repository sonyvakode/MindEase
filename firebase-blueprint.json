{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public and private user profile information.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email"]
    },
    "Mood": {
      "title": "Mood Entry",
      "description": "Daily mood tracking entry.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mood": { "type": "string" },
        "score": { "type": "integer" },
        "date": { "type": "string", "format": "date" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mood", "score", "timestamp"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Scheduled therapy session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "specialistId": { "type": "string" },
        "specialistName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "specialistId", "date", "time", "status", "createdAt"]
    },
    "Specialist": {
      "title": "Specialist",
      "description": "Mental health professional.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specialty": { "type": "string" },
        "image": { "type": "string" },
        "rating": { "type": "number" },
        "verified": { "type": "boolean" }
      },
      "required": ["name", "specialty", "image"]
    },
    "Resource": {
      "title": "Wellness Resource",
      "description": "Article, video, or audio content.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "duration": { "type": "string" },
        "image": { "type": "string" },
        "url": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "image"]
    },
    "CommunityPost": {
      "title": "Community Post",
      "description": "Anonymized community support post.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "text": { "type": "string" },
        "likes": { "type": "integer" },
        "comments": { "type": "integer" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Profiles for registered users."
    },
    "/moods/{moodId}": {
      "schema": "Mood",
      "description": "Global mood entries, filtered by userId for privacy."
    },
    "/specialists/{specialistId}": {
      "schema": "Specialist",
      "description": "List of available therapists."
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "User appointments."
    },
    "/resources/{resourceId}": {
      "schema": "Resource",
      "description": "Wellness content library."
    },
    "/community_posts/{postId}": {
      "schema": "CommunityPost",
      "description": "Public feed of support posts."
    }
  }
}
